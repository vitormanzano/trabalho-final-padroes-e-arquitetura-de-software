# Credenciais de acesso ao banco Oracle.
# Copie este arquivo para ".env" e preencha os valores.
# O arquivo ".env" é ignorado pelo git — as credenciais reais
# não vão para o repositório.

# Exemplo de ambiente local:
#   DB_USER=system
#   DB_PASSWORD=Oracle123
#   DB_DSN=localhost/xe

DB_USER=
DB_PASSWORD=
DB_DSN=
