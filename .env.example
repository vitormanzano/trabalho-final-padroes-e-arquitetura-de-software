# Credenciais de acesso ao banco PostgreSQL.
# Copie este arquivo para ".env" e preencha os valores.
# O arquivo ".env" é ignorado pelo git — as credenciais reais
# não vão para o repositório.

# Exemplo de ambiente local:
#   DB_HOST=localhost
#   DB_PORT=5432
#   DB_NAME=produtos
#   DB_USER=postgres
#   DB_PASSWORD=postgres

DB_HOST=localhost
DB_PORT=5432
DB_NAME=
DB_USER=
DB_PASSWORD=
